---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { CATS, getSections, sigTier, sigBarsOn, agoLabel } from '../lib/data.js';

const { section, story, prev, next, dateISO = null } = Astro.props;
const sections = getSections();

// Source chips: new-format entries are {d, u} objects linking to the exact
// article; legacy entries are plain domain strings (link to the outlet) or
// "+N" overflow counts.
const chips = story.l.map((x) => {
  const d = typeof x === 'string' ? x : x.d;
  const isMore = d.startsWith('+');
  const u =
    typeof x === 'object' && x.u ? x.u : !isMore && typeof x === 'string' ? `https://${d}` : null;
  return { d, u, isMore };
});

const description = story.s;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: story.h,
  description: story.s,
  datePublished: story.ts ?? (dateISO ? `${dateISO}T12:00:00Z` : undefined),
  dateModified: story.ts ?? undefined,
  author: { '@type': 'Organization', name: 'AI News Radar' },
  publisher: { '@type': 'Organization', name: 'AI News Radar' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---
<Base title={`${story.h} — AI News Radar`} description={description}>
  <Nav slot="nav" sections={sections} currentId={section.id} />

  <a class="crumb" href={section.url}>← {section.title} · {section.sub}</a>

  <article class="article">
    <div class="article-meta">
      <span class={`cat ${story.cat}`}><i></i>{CATS[story.cat]}</span>
      {story.date ? (
        <span class="srcmeta">{story.date}</span>
      ) : (
        <span class="srcmeta">{story.sources} sources covering</span>
      )}
      {story.ts && <span class="srcmeta ago" data-ts={story.ts}>{agoLabel(story.ts)}</span>}
      <span class={`sigpill ${sigTier(story.signal)}`} title="Signal score — how widely and seriously this is covered">
        <span class="bars">
          {[1, 2, 3, 4].map((n) => (
            <i class={n <= sigBarsOn(story.signal) ? 'on' : ''}></i>
          ))}
        </span>
        {story.signal}
      </span>
      <button class="sharebtn" type="button">Share</button>
    </div>

    <h1>{story.h}</h1>
    <p class="lede">{story.s}</p>

    <div class="facts">
      <h2>At a glance</h2>
      <ul>
        {story.b.map((x) => (
          <li>{x}</li>
        ))}
      </ul>
    </div>

    {story.body && story.body.length > 0 && (
      <div class="body">
        <h2>The story</h2>
        {story.body.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    )}

    <div class="coverage">
      <h2>Coverage</h2>
      <div class="srcrow">
        {chips.map((c) =>
          c.u ? (
            <a href={c.u} target="_blank" rel="noopener">{c.d} ↗</a>
          ) : (
            <span>{c.isMore ? `${c.d} more outlets` : c.d}</span>
          )
        )}
      </div>
    </div>
  </article>

  <nav class="pager" aria-label="Adjacent stories">
    {prev ? <a href={prev.url}>← {prev.h.slice(0, 44)}{prev.h.length > 44 ? '…' : ''}</a> : <span></span>}
    {next ? <a href={next.url}>{next.h.slice(0, 44)}{next.h.length > 44 ? '…' : ''} →</a> : <span></span>}
  </nav>

  <div class="feed-end">
    <div class="subcard" id="subcard">
      <h3>Get tomorrow's scan at 7am</h3>
      <p>The same ranked list, in your inbox. Nothing else, ever.</p>
      <form class="subform">
        <input type="email" placeholder="you@example.com" aria-label="Email address" required />
        <button type="submit">Subscribe</button>
      </form>
    </div>
    <p class="colophon"><a href={section.url}>← Back to {section.title}</a></p>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</Base>
