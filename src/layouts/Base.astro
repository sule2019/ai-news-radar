---
import '../styles/global.css';

const { title, description, page = 'default' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AI News Radar" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body data-page={page}>
    <nav class="nav">
      <div class="nav-inner">
        <a class="wordmark" href="/">
          <span class="sigicon"><i></i><i></i><i></i></span>AI News Radar
        </a>
        <slot name="nav" />
        <a class="subbtn" href="#subcard">Subscribe</a>
      </div>
    </nav>

    <div class="page">
      <slot />
    </div>

    <script>
      // Relative timestamps ("12m ago", "3h ago") — computed in the browser
      // so they stay accurate between hourly rebuilds. Hidden past 24h; the
      // day header dates older stories.
      const formatAgo = (root: ParentNode = document) => {
        root.querySelectorAll('.ago[data-ts]').forEach((el) => {
          const mins = Math.round((Date.now() - Date.parse((el as HTMLElement).dataset.ts!)) / 60000);
          if (!Number.isFinite(mins) || mins < 0 || mins >= 24 * 60) {
            el.remove();
          } else {
            el.textContent = mins < 1 ? 'just now' : mins < 60 ? `${mins}m ago` : `${Math.round(mins / 60)}h ago`;
          }
        });
      };
      formatAgo();
      (window as any).formatAgo = formatAgo; // used by the homepage lazy loader

      // "New" badges: mark today's stories that broke since the reader's
      // previous visit. Purely client-side (localStorage) — no tracking.
      // Visits <30min apart count as one sitting so badges survive refreshes.
      try {
        const KEY = 'anr-visits';
        const now = Date.now();
        const stored = JSON.parse(localStorage.getItem(KEY) || 'null');
        let prevVisit = null;
        if (stored) {
          prevVisit = now - stored.last > 30 * 60 * 1000 ? stored.last : stored.prev;
          localStorage.setItem(KEY, JSON.stringify({ last: now, prev: prevVisit }));
        } else {
          localStorage.setItem(KEY, JSON.stringify({ last: now, prev: null }));
        }
        if (prevVisit) {
          const today = new Date().toDateString();
          document.querySelectorAll('.story').forEach((story) => {
            const tsEl = story.querySelector('[data-ts]');
            if (!tsEl) return;
            const ts = Date.parse((tsEl as HTMLElement).dataset.ts!);
            if (ts > prevVisit! && new Date(ts).toDateString() === today) {
              const headline = story.querySelector('.headline');
              if (headline && !headline.querySelector('.newchip')) {
                const chip = document.createElement('span');
                chip.className = 'newchip';
                chip.textContent = 'New';
                headline.prepend(chip);
              }
            }
          });
        }
      } catch {
        /* localStorage unavailable (private mode etc.) — no badges */
      }

      // Share: native share sheet on mobile, copy-link on desktop
      document.querySelectorAll('.sharebtn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const payload = { title: document.title, url: location.href };
          if (navigator.share) {
            try {
              await navigator.share(payload);
            } catch {
              /* user dismissed the sheet */
            }
          } else {
            try {
              await navigator.clipboard.writeText(payload.url);
              const prev = btn.textContent;
              btn.textContent = 'Link copied ✓';
              setTimeout(() => (btn.textContent = prev), 1800);
            } catch {
              window.prompt('Copy this link:', payload.url);
            }
          }
        });
      });

      // Newsletter form (placeholder until a provider is wired up)
      document.querySelectorAll('.subform').forEach((form) => {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const btn = (form as HTMLElement).querySelector('button');
          if (btn) btn.textContent = 'Subscribed';
        });
      });

      // Homepage: pills scroll to the section instead of navigating,
      // and the URL follows the day you're reading (real, shareable URLs).
      if (document.body.dataset.page === 'home') {
        const pills = [...document.querySelectorAll('.seg a[data-section]')] as HTMLAnchorElement[];

        pills.forEach((pill) => {
          pill.addEventListener('click', (e) => {
            const target = document.getElementById(pill.dataset.section || '');
            if (!target) return; // fall through to normal navigation
            e.preventDefault();
            target.scrollIntoView({ block: 'start' });
          });
        });

        const sync = () => {
          // Query live — older days are appended to the feed as they lazy-load
          const sections = [...document.querySelectorAll('section.day[data-url]')] as HTMLElement[];
          let active: HTMLElement | null = null;
          for (const sec of sections) {
            if (sec.getBoundingClientRect().top <= 130) active = sec;
          }
          pills.forEach((p) => p.classList.toggle('active', !!active && p.dataset.section === active.id));
          const url = active && window.scrollY > 40 ? active.dataset.url! : '/';
          if (location.pathname !== url) history.replaceState(null, '', url);
        };
        addEventListener('scroll', sync, { passive: true });
        sync();
      }
    </script>
  </body>
</html>
